{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm install:*)",
      "Bash(if exist node_modules rmdir /s /q node_modules)",
      "Bash(if exist package-lock.json del package-lock.json)",
      "Bash(npm run dev:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(tasklist:*)",
      "Bash(findstr:*)",
      "Bash(npm run build:*)",
      "Bash(timeout /t 5 /nobreak)",
      "Bash(timeout:*)"
    ]
  }
}
